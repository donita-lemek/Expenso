# ── App Environment ─────────────────────────────────────
ENV=local   # Set to "production" on Cloud Run

# ── Gemini API ──────────────────────────────────────────
GEMINI_API_KEY=your_gemini_key_here

# ── FastAPI (used by Streamlit frontend) ─────────────────
FASTAPI_URL=http://localhost:8000

# ── GCP ──────────────────────────────────────────────────
GCP_PROJECT_ID=expenso-app
GCP_BUCKET_NAME=expenso-receipts
GCP_REGION=asia-south1
